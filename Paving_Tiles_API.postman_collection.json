{
  "info": {
    "name": "Paving Tiles API",
    "description": "API для управления каталогом тротуарной плитки",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:4200/health",
          "host": ["localhost"],
          "port": "4200",
          "path": ["health"]
        }
      }
    },
    {
      "name": "Create Tile",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Брусчатка Классик\",\n  \"shape\": \"rectangle\",\n  \"color\": \"серый\",\n  \"size\": \"200x100x60\",\n  \"material\": \"бетон\",\n  \"price_per_m2\": 850.50,\n  \"stock\": 1500,\n  \"description\": \"Классическая брусчатка для пешеходных зон\",\n  \"image_url\": \"https://example.com/brick.jpg\"\n}"
        },
        "url": {
          "raw": "http://localhost:4200/api/v1/tiles",
          "host": ["localhost"],
          "port": "4200",
          "path": ["api", "v1", "tiles"]
        }
      }
    },
    {
      "name": "Get All Tiles (with Pagination)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:4200/api/v1/tiles?page=1&limit=10",
          "host": ["localhost"],
          "port": "4200",
          "path": ["api", "v1", "tiles"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Get Tile By ID",
      "request": {
        "method": "GET",
        "header": [],
